{
  "title": "Sandbox Tracing Demo",
  "uid": "sandbox-tracing-demo",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "tags": ["sandbox", "tracing", "demo"],
  "templating": {
    "list": [
      {
        "name": "operation",
        "type": "query",
        "datasource": {
          "type": "jaeger",
          "uid": "jaeger"
        },
        "query": "sandbox-manager",
        "refresh": 1,
        "includeAll": true,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Trace 搜索 — 全部操作",
      "type": "table",
      "datasource": {
        "type": "jaeger",
        "uid": "jaeger"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "jaeger",
            "uid": "jaeger"
          },
          "query": {
            "service": "sandbox-manager",
            "limit": 50
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Trace ID"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View Trace",
                    "url": "/d/sandbox-trace-detail?traceId=${__value.text}",
                    "targetBlank": false
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Duration",
            "desc": true
          }
        ]
      }
    },
    {
      "id": 2,
      "title": "创建沙箱 — Trace 列表",
      "type": "table",
      "datasource": {
        "type": "jaeger",
        "uid": "jaeger"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "jaeger",
            "uid": "jaeger"
          },
          "query": {
            "service": "sandbox-manager",
            "operation": "POST /sandboxes",
            "limit": 20
          }
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 3,
