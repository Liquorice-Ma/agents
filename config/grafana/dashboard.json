      "datasource": {
        "type": "jaeger",
        "uid": "jaeger"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
